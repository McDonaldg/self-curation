<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>朝のキュレーション — {{ date }}</title>
<link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;700&family=Zen+Kaku+Gothic+New:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1f2833;        /* 濃藍のインク */
    --paper: #fbfaf7;      /* 朝の紙面 */
    --dim: #6b7280;
    --line: #d9d6cd;
    --main-accent: #2f5d8a;   /* 普段の関心: 藍 */
    --ser-accent: #b3543e;    /* セレンディピティ: 弁柄色 */
  }
  * { box-sizing: border-box; margin: 0; }
  body {
    background: var(--paper);
    color: var(--ink);
    font-family: "Zen Kaku Gothic New", sans-serif;
    line-height: 1.9;
    max-width: 680px;
    margin: 0 auto;
    padding: 3rem 1.25rem 5rem;
  }
  header { border-bottom: 3px double var(--line); padding-bottom: 1.2rem; margin-bottom: 2.5rem; }
  header .kicker { font-size: .75rem; letter-spacing: .35em; color: var(--dim); }
  header h1 {
    font-family: "Shippori Mincho", serif;
    font-size: 1.7rem; font-weight: 700; margin-top: .3rem;
  }
  .legend { font-size: .75rem; color: var(--dim); margin-top: .6rem; }
  .legend .dot { display: inline-block; width: .6em; height: .6em; border-radius: 50%; margin: 0 .3em 0 1em; }
  .dot.main { background: var(--main-accent); }
  .dot.ser  { background: var(--ser-accent); }

  article { margin-bottom: 2.2rem; padding-left: 1rem; border-left: 3px solid var(--main-accent); }
  article.serendipity { border-left-color: var(--ser-accent); }
  article h2 { font-family: "Shippori Mincho", serif; font-size: 1.1rem; line-height: 1.6; }
  article h2 a { color: inherit; text-decoration: none; }
  article h2 a:hover { text-decoration: underline; }
  article .summary { margin-top: .5rem; font-size: .95rem; }
  article .premise {
    margin-top: .5rem; font-size: .8rem; color: var(--dim);
  }
  article .premise::before { content: "暗黙の前提 — "; color: var(--ink); font-weight: 500; }
  article .feedback {
    margin-top: .5rem; font-size: .72rem; color: var(--dim);
  }
  article .feedback code {
    background: #efece4; padding: .1em .4em; border-radius: 3px; font-size: .95em;
  }

  section.cross { margin-top: 3.5rem; }
  section.cross h2, section.questions h2 {
    font-family: "Shippori Mincho", serif;
    font-size: 1rem; letter-spacing: .2em;
    border-bottom: 1px solid var(--line);
    padding-bottom: .4rem; margin-bottom: 1rem;
  }
  .insight {
    background: #fff; border: 1px solid var(--line);
    padding: 1rem 1.2rem; margin-bottom: 1rem; font-size: .95rem;
    border-radius: 2px;
  }
  section.questions { margin-top: 3rem; }
  .question {
    font-family: "Shippori Mincho", serif;
    font-size: 1.02rem; margin-bottom: 1.1rem; padding-left: 1.6rem; position: relative;
  }
  .question::before { content: "問"; position: absolute; left: 0; color: var(--ser-accent); font-weight: 700; }
  footer { margin-top: 4rem; font-size: .7rem; color: var(--dim); text-align: center; }
</style>
</head>
<body>
<header>
  <div class="kicker">SELF-CURATION</div>
  <h1>朝のキュレーション <span style="font-size:.8em; color:var(--dim);">{{ date }}</span></h1>
  <div class="legend">
    <span class="dot main"></span>普段の関心
    <span class="dot ser"></span>セレンディピティ枠
  </div>
</header>

{% for a in digest.articles %}
<article class="{{ 'serendipity' if a.source == 'serendipity' }}">
  <h2><a href="{{ a.url }}" target="_blank" rel="noopener">{{ a.title }}</a></h2>
  <p class="summary">{{ a.summary }}</p>
  <p class="premise">{{ a.hidden_premise }}</p>
  {% if a.id %}
  <p class="feedback">評価: <code>python main.py feedback {{ a.id }} up</code> / <code>python main.py feedback {{ a.id }} down</code></p>
  {% endif %}
</article>
{% endfor %}

<section class="cross">
  <h2>異分野クロス洞察</h2>
  {% for ins in digest.cross_insights %}
  <div class="insight">{{ ins }}</div>
  {% endfor %}
</section>

<section class="questions">
  <h2>今日の問い</h2>
  {% for q in digest.questions %}
  <p class="question">{{ q }}</p>
  {% endfor %}
</section>

<footer>generated by self-curation pipeline</footer>
</body>
</html>
